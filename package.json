{
  "name": "passport-photo",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "bun node_modules/vite/bin/vite.js dev",
    "build": "bun node_modules/vite/bin/vite.js build",
    "preview": "bun node_modules/vite/bin/vite.js preview",
    "test": "bun node_modules/vitest/vitest.mjs",
    "test:e2e": "LD_LIBRARY_PATH=$(./scripts/playwright-lib-path.sh) PLAYWRIGHT_SKIP_VALIDATE_HOST_REQUIREMENTS=1 bunx playwright test",
    "check": "bun node_modules/@sveltejs/kit/svelte-kit.js sync && bun node_modules/svelte-check/bin/svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "bun node_modules/@sveltejs/kit/svelte-kit.js sync && bun node_modules/svelte-check/bin/svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-static": "^3.0.8",
    "@sveltejs/kit": "^2.16.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
"svelte": "^5.20.0",
    "svelte-check": "^4.1.5",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "changedpi": "^1.0.4"
  },
  "type": "module"
}
